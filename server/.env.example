# Copy to .env and fill in.

# Local Postgres (docker compose up -d db):
DATABASE_URL="postgresql://mixdeck:mixdeck@localhost:5432/mixdeck"
# ...or develop against the deployed instance's database (see DEPLOY.md):
# DATABASE_URL="postgresql://mixdeck:<POSTGRES_PASSWORD>@<instance-ip>:5432/mixdeck"

JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000

# Optional overrides (defaults are right for local dev):
# CORS_ORIGIN="http://localhost:5173"   # Vite dev server; unused in production
# CLIENT_DIST="../client/dist"          # serve the built SPA (production mode)
# UPLOADS_DIR="uploads"

# Phase 4+ (leave blank for now)
SPOTIFY_CLIENT_ID=""
# Phase 6+ (server-side only; never exposed to the browser)
ANTHROPIC_API_KEY=""
