# Copy to .env on the deployment instance (next to docker-compose.prod.yml).

# Generate each secret with: openssl rand -hex 32
POSTGRES_PASSWORD=
JWT_SECRET=

# Your domain (e.g. mix.example.com) for automatic HTTPS.
# No domain yet? Use DOMAIN=:80 and INSECURE_COOKIES=1 (see DEPLOY.md).
DOMAIN=
INSECURE_COOKIES=0
